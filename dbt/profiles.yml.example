# Example dbt profile for this project.
# Actual profiles.yml should live in ~/.dbt/ and not be committed.

nba_analytics:
  target: dev
  outputs:
    dev:
      type: bigquery
      method: service-account
      project: your-gcp-project-id
      dataset: nba_analytics_dev
      threads: 4
      keyfile: /path/to/service-account.json
      location: US
      priority: interactive
